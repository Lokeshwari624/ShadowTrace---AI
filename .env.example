# ShadowTrace AI — Environment configuration
#
# Copy this file to `.env.local` and edit values.
# NEVER commit secrets. Frontend variables are public — use a backend
# proxy (edge function) for any private API key.

# Base URL of your real backend. Leave empty to use local mock simulation.
VITE_API_BASE_URL=

# Force mock data even if VITE_API_BASE_URL is set ("true" / "false").
VITE_USE_MOCK_API=true

# Public app metadata
VITE_APP_NAME=ShadowTrace AI
